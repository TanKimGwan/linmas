{
  "schemaVersion": 1,
  "id": "baseline-appsec",
  "version": "1.0.0",
  "description": "Baseline application security review conditions",
  "specialists": [
    "secure-code-reviewer"
  ],
  "modes": [
    "advisor-review"
  ],
  "acceptedInputs": [
    "text",
    "diff",
    "code"
  ],
  "rules": [
    {
      "id": "checks",
      "type": "minimum-checks",
      "checks": [
        "security regression test"
      ]
    },
    {
      "id": "high",
      "type": "finding-threshold",
      "severities": [
        "Critical",
        "High"
      ],
      "status": "blocked"
    }
  ],
  "humanReview": {
    "required": true,
    "statement": "A human reviewer must approve the decision."
  }
}
